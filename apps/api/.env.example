PORT=3001
CORS_ORIGIN=http://localhost:5173,https://ahnsungkwon.github.io
MARKET_DATA_PROVIDER=kis

# prod = 실전투자, vps = 모의투자
KIS_ENV=prod
KIS_BASE_URL=

# Fill these only in apps/api/.env.kis.local. Never commit real values.
KIS_APP_KEY=
KIS_APP_SECRET=

# This MVP uses KIS REST polling and serves frontend updates over /realtime WS.
KIS_USE_WS=false
KIS_POLL_MS=15000

# Kiwoom REST provider. Use this block with MARKET_DATA_PROVIDER=kiwoom.
KIWOOM_ENV=prod
KIWOOM_BASE_URL=
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_POLL_MS=15000

WATCH_SYMBOLS=005930,000660,005380,035420,051910,068270
